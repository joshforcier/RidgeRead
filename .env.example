# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Firebase Admin SDK (server)
# Path to your Firebase service-account JSON, downloaded from
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key.
# Required by the server to verify ID tokens and read/write usage counters.
GOOGLE_APPLICATION_CREDENTIALS=./terrainiq-firebase-adminsdk-fbsvc-74ea9dcbdb.json

# Firebase (get these from Firebase Console → Project Settings → Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Mapbox (get a free token at https://account.mapbox.com)
VITE_MAPBOX_TOKEN=
